FoamFile
{
    format      ascii;
    class       dictionary;
    object      foamToNumpyDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
dataDir       data;
fields
{ 
    names       (p U);
    dataType    float64;
}
exportData
{
    cellCentre   true;
    cellVolumes  true;
    writeTimes   true;
    dataType     float64;
}
storageOrder   F;         // F or C
time          
{
    startTime     0.0;
    endTime       0.5;
    every         1;
}




