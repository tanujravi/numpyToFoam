FoamFile
{
    format      ascii;
    class       dictionary;
    object      foamToNumpyDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
dataDir       data;
fields        (p U UPrime2Mean);
exportData
{
    cellCentre   false;
    cellVolumes  false;
    writeTimes   false;
}
dataType    float32;
time          
{
    startTime     8.0;
    endTime       12.0;
    every         1;
}



